<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".CheckoutPageActivity">

    <TextView
        android:id="@+id/title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:gravity="center"
        android:text="Checkout"
        android:textColor="@color/black"
        android:textSize="30sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/tamakListLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/title"
        android:layout_margin="10dp"
        android:layout_marginTop="50dp"
        android:orientation="horizontal">


        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="10dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    tools:context=".MainActivity">

                    <ImageView
                        android:id="@+id/tamak1_suret"
                        android:layout_width="150dp"
                        android:layout_height="150dp"
                        android:src="@drawable/type_1_01" />

                    <LinearLayout
                        android:layout_width="930dp"
                        android:layout_height="200dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tamak1_title"
                            android:layout_width="200dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Brie Cheese"
                            android:textColor="@color/black"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/tamak1_price"
                            android:layout_width="200dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Price"
                            android:textColor="@color/black"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/tamak1_desc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Status: Order placed"
                            android:textColor="@color/black"
                            android:textSize="30sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Count"
                            android:textColor="@color/black"
                            android:textSize="20sp" />

                    </LinearLayout>

                    <Button
                        android:id="@+id/delete"
                        style="@style/Widget.Material3.Button.ElevatedButton"
                        android:layout_width="150dp"
                        android:layout_height="match_parent"
                        android:layout_below="@id/close"
                        android:background="@color/white"
                        android:text="Clear"
                        android:textAlignment="center"
                        android:textColor="@color/kyzyl"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        app:backgroundTint="@null" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginTop="15dp"
                    tools:context=".MainActivity">

                    <ImageView
                        android:id="@+id/tamak2_suret"
                        android:layout_width="150dp"
                        android:layout_height="150dp"
                        android:src="@drawable/type_1_01" />

                    <LinearLayout
                        android:layout_width="930dp"
                        android:layout_height="200dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tamak2_title"
                            android:layout_width="200dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Brie Cheese"
                            android:textColor="@color/black"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/tamak2_price"
                            android:layout_width="200dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Price"
                            android:textColor="@color/black"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/tamak2_desc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Status: Cooking"
                            android:textColor="@color/sary"
                            android:textSize="30sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Count"
                            android:textColor="@color/black"
                            android:textSize="20sp" />

                    </LinearLayout>

                    <Button
                        android:id="@+id/clear2"
                        style="@style/Widget.Material3.Button.ElevatedButton"
                        android:layout_width="150dp"
                        android:layout_height="match_parent"
                        android:layout_below="@id/close"
                        android:background="@color/white"
                        android:text="Clear"
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        app:backgroundTint="@null" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginTop="15dp"
                    tools:context=".MainActivity">

                    <ImageView
                        android:layout_width="150dp"
                        android:layout_height="150dp"
                        android:src="@drawable/type_1_01" />

                    <LinearLayout
                        android:layout_width="930dp"
                        android:layout_height="200dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tamak3_title"
                            android:layout_width="200dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Brie Cheese"
                            android:textColor="@color/black"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/tamak3_price"
                            android:layout_width="200dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Price"
                            android:textColor="@color/black"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/tamak3_desc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Status: Served"
                            android:textColor="@color/jasyl"
                            android:textSize="30sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Count"
                            android:textColor="@color/black"
                            android:textSize="20sp" />

                    </LinearLayout>

                    <Button
                        android:id="@+id/clear3"
                        style="@style/Widget.Material3.Button.ElevatedButton"
                        android:layout_width="150dp"
                        android:layout_height="match_parent"
                        android:layout_below="@id/close"
                        android:background="@color/white"
                        android:text="Clear"
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        app:backgroundTint="@null" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginTop="15dp"
                    tools:context=".MainActivity">

                    <ImageView
                        android:layout_width="150dp"
                        android:layout_height="150dp"
                        android:src="@drawable/type_1_01" />

                    <LinearLayout
                        android:layout_width="930dp"
                        android:layout_height="200dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tamak4_title"
                            android:layout_width="200dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Brie Cheese"
                            android:textColor="@color/black"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/tamak4_price"
                            android:layout_width="200dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Price"
                            android:textColor="@color/black"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/tamak4_desc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Status: Order placed"
                            android:textColor="@color/black"
                            android:textSize="30sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Count"
                            android:textColor="@color/black"
                            android:textSize="20sp" />

                    </LinearLayout>

                    <Button
                        style="@style/Widget.Material3.Button.ElevatedButton"
                        android:layout_width="150dp"
                        android:layout_height="match_parent"
                        android:layout_below="@id/close"
                        android:background="@color/white"
                        android:text="Clear"
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        app:backgroundTint="@null" />

                </LinearLayout>


            </LinearLayout>

        </ScrollView>

    </LinearLayout>

    <RelativeLayout
        android:layout_width="400dp"
        android:layout_height="140dp"
        android:layout_alignParentRight="true"
        android:layout_alignParentBottom="true"
        android:background="@color/white"
        android:layout_margin="40dp">

        <TextView
            android:id="@+id/total_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:text="Total:"
            android:textColor="@color/black"
            android:textSize="30sp"/>

        <TextView
            android:id="@+id/total_san"
            android:layout_below="@id/total_text"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginLeft="10dp"
            android:gravity="center_vertical"
            android:text="E 30"
            android:textColor="@color/black"
            android:textSize="50sp"/>

        <Button
            android:id="@+id/add_dish"
            style="@style/Widget.Material3.Button.ElevatedButton"
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:layout_alignParentRight="true"
            android:text="Add Dish"
            android:textAlignment="center"
            android:textColor="@color/black"
            android:textSize="30sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />

        <TextView
            android:layout_below="@id/add_dish"
            android:layout_width="180dp"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:background="@color/black"
            android:layout_alignParentRight="true"
            android:textColor="@color/black"/>

        <Button
            android:id="@+id/checkout"
            style="@style/Widget.Material3.Button.ElevatedButton"
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:layout_alignParentRight="true"
            android:layout_alignParentBottom="true"
            android:text="Checkout"
            android:textAlignment="center"
            android:textColor="@color/black"
            android:textSize="30sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />


    </RelativeLayout>


</RelativeLayout>