<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">


    <Button
        android:id="@+id/clearAll"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Clear All"
        android:textAlignment="center"
        android:textSize="20sp" />

    <TextView
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:text="Cart"
        android:textAlignment="center"
        android:textColor="@color/black"
        android:textSize="30sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/close"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:text="Close"
        android:textAlignment="center"
        android:textSize="20sp" />

    <Button
        android:id="@+id/submit"
        android:layout_below="@id/close"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Submit Order"
        android:textAlignment="center"
        android:textSize="20sp" />

    <LinearLayout
        android:id="@+id/tamakListLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/submit"
        android:layout_margin="10dp"
        android:layout_marginTop="50dp"
        android:orientation="horizontal">


        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="10dp"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/tamak1_layout"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    tools:context=".MainActivity">

                    <ImageView
                        android:id="@+id/tamak1_suret"
                        android:layout_width="150dp"
                        android:layout_height="150dp"
                        android:src="@drawable/type_1_01" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="150dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tamak1_title"
                            android:layout_width="200dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Brie Cheese"
                            android:textColor="@color/black"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/tamak1_price"
                            android:layout_width="200dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Price"
                            android:textColor="@color/black"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/tamak1_desc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Desciption"
                            android:textColor="@color/black"
                            android:textSize="20sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="right"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/delete"
                                android:layout_below="@id/close"
                                android:layout_width="300dp"
                                android:layout_height="wrap_content"
                                android:text="Delete"
                                android:textAlignment="center"
                                android:textSize="20sp" />

                            <ImageView
                                android:id="@+id/tamak1_minus"
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:src="@drawable/icon_del" />

                            <TextView
                                android:id="@+id/tamak1_san"
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:layout_marginLeft="10dp"
                                android:gravity="center"
                                android:text="10"
                                android:textColor="@color/black"
                                android:textSize="20sp" />

                            <ImageView
                                android:id="@+id/tamak1_plus"
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:src="@drawable/icon_add" />

                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
