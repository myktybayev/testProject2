<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Menu"
        android:textAlignment="center"
        android:textColor="@color/black"
        android:textSize="30sp"
        android:layout_centerHorizontal="true"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:scrollbars="vertical">

        <Button
            android:id="@+id/btnCart"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="1000dp"
            android:text="Cart"
            android:textAlignment="center"
            android:textSize="20sp" />

        <TextView
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:text="Recommended"
            android:textAlignment="center"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="300dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:scrollbars="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/tamak1_suret"
                        android:layout_width="300dp"
                        android:layout_height="300dp"
                        android:layout_marginLeft="30dp"
                        android:src="@drawable/type_1_01" />

                    <LinearLayout
                        android:layout_width="300dp"
                        android:layout_height="300dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tamak1_name"
                            android:layout_width="200dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Brie Cheese"
                            android:textColor="@color/black"
                            android:textSize="20sp" />

                        <RatingBar
                            android:id="@+id/tamak1_ratingBar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:numStars="5" />

                        <TextView
                            android:id="@+id/tamak1_desc"
                            android:layout_width="300dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Sign must be ordered, netizens recommend"
                            android:textColor="@color/black"
                            android:textSize="20sp" />

                    </LinearLayout>

                    <ImageView
                        android:id="@+id/tamak2_suret"
                        android:layout_width="300dp"
                        android:layout_height="300dp"
                        android:layout_marginLeft="30dp"
                        android:src="@drawable/type_1_02" />

                    <LinearLayout
                        android:layout_width="300dp"
                        android:layout_height="300dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tamak2_name"
                            android:layout_width="200dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Conte Cheese"
                            android:textColor="@color/black"
                            android:textSize="20sp" />

                        <RatingBar
                            android:id="@+id/tamak2_ratingBar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:numStars="5" />

                        <TextView
                            android:id="@+id/tamak2_desc"
                            android:layout_width="300dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Monthly sales 70"
                            android:textColor="@color/black"
                            android:textSize="20sp" />

                    </LinearLayout>

                    <ImageView
                        android:id="@+id/tamak3_suret"
                        android:layout_width="300dp"
                        android:layout_height="300dp"
                        android:layout_marginLeft="30dp"
                        android:src="@drawable/type_1_03" />

                    <LinearLayout
                        android:layout_width="300dp"
                        android:layout_height="300dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tamak3_name"
                            android:layout_width="200dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Camembert Cheese"
                            android:textColor="@color/black"
                            android:textSize="20sp" />

                        <RatingBar
                            android:id="@+id/tamak3_ratingBar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:numStars="5" />

                        <TextView
                            android:id="@+id/tamak3_desc"
                            android:layout_width="300dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Monthly sales 100+ praise 60%"
                            android:textColor="@color/black"
                            android:textSize="20sp" />

                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

        </HorizontalScrollView>

        <TextView
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Hot"
            android:textAlignment="center"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold" />


        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="300dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:scrollbars="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/tamak4_suret"
                        android:layout_width="300dp"
                        android:layout_height="300dp"
                        android:layout_marginLeft="30dp"
                        android:src="@drawable/type_1_04" />

                    <LinearLayout
                        android:layout_width="300dp"
                        android:layout_height="300dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tamak4_name"
                            android:layout_width="200dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Title"
                            android:textColor="@color/black"
                            android:textSize="20sp" />

                        <RatingBar
                            android:id="@+id/tamak4_ratingBar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:numStars="5" />

                        <TextView
                            android:id="@+id/tamak4_desc"
                            android:layout_width="300dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Sign must be ordered, netizens recommend. Sign must be ordered, netizens recommend. Sign must be ordered, netizens recommend.Sign must be ordered, netizens recommend"
                            android:textColor="@color/black"
                            android:textSize="20sp" />

                    </LinearLayout>

                    <ImageView
                        android:id="@+id/tamak5_suret"
                        android:layout_width="300dp"
                        android:layout_height="300dp"
                        android:layout_marginLeft="30dp"
                        android:src="@drawable/type_1_04" />

                    <LinearLayout
                        android:layout_width="300dp"
                        android:layout_height="300dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tamak5_name"
                            android:layout_width="200dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Title"
                            android:textColor="@color/black"
                            android:textSize="20sp" />

                        <RatingBar
                            android:id="@+id/tamak5_ratingBar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:numStars="5" />

                        <TextView
                            android:id="@+id/tamak5_desc"
                            android:layout_width="300dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Sign must be ordered, netizens recommend. Sign must be ordered, netizens recommend. Sign must be ordered, netizens recommend.Sign must be ordered, netizens recommend"
                            android:textColor="@color/black"
                            android:textSize="20sp" />

                    </LinearLayout>

                    <ImageView
                        android:id="@+id/tamak6_suret"
                        android:layout_width="300dp"
                        android:layout_height="300dp"
                        android:layout_marginLeft="30dp"
                        android:src="@drawable/type_1_04" />

                    <LinearLayout
                        android:layout_width="300dp"
                        android:layout_height="300dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tamak6_name"
                            android:layout_width="200dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Title"
                            android:textColor="@color/black"
                            android:textSize="20sp" />

                        <RatingBar
                            android:id="@+id/tamak6_ratingBar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:numStars="5" />

                        <TextView
                            android:id="@+id/tamak6_desc"
                            android:layout_width="300dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:text="Sign must be ordered, netizens recommend. Sign must be ordered, netizens recommend. Sign must be ordered, netizens recommend.Sign must be ordered, netizens recommend"
                            android:textColor="@color/black"
                            android:textSize="20sp" />

                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>

        </HorizontalScrollView>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_margin="10dp">

        <Button
            android:id="@+id/menuBtn"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginLeft="5dp"
            android:layout_weight="1"
            android:background="@color/white"
            android:text="Menu"
            android:textColor="@color/blue"
            android:textSize="20dp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/categoryBtn"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginLeft="5dp"
            android:layout_weight="1"
            android:text="Category"
            android:textSize="20dp" />

    </LinearLayout>

</RelativeLayout>